{
  "name": "sparekart",
  "private": true,
  "version": "1.0.0",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:backend dev:frontend",
    "dev:frontend": "npm --workspace frontend run dev",
    "dev:backend": "npm --workspace backend run dev",
    "build": "sh -c 'if [ \"$VERCEL\" = \"1\" ]; then npm run build:frontend; else npm-run-all build:backend build:frontend; fi'",
    "build:frontend": "npm --workspace frontend run build",
    "build:backend": "npm --workspace backend run build",
    "lint": "npm-run-all lint:backend lint:frontend",
    "lint:frontend": "npm --workspace frontend run lint",
    "lint:backend": "npm --workspace backend run lint",
    "db:push": "npm --workspace backend run prisma:push",
    "db:seed": "npm --workspace backend run prisma:seed"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
