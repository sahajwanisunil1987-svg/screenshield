generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  COD
}

enum CouponType {
  PERCENTAGE
  FLAT
}

enum ReviewStatus {
  PENDING
  APPROVED
  HIDDEN
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SupportTicketKind {
  ORDER_ISSUE
  RETURN_ISSUE
  PAYMENT_ISSUE
  PRODUCT_INQUIRY
  OTHER
}

enum SupportTicketStatus {
  NEW
  IN_PROGRESS
  RESOLVED
}

model Brand {
  id          String        @id @default(cuid())
  name        String        @unique
  slug        String        @unique
  logoUrl     String?
  isActive    Boolean       @default(true)
  description String?
  models      MobileModel[]
  products    Product[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([slug, isActive])
}

model MobileModel {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  imageUrl    String?
  brandId     String
  brand       Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  isActive    Boolean   @default(true)
  products    Product[]
  compatibleProducts ProductCompatibility[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([brandId, name])
  @@index([brandId, slug, isActive])
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  usesVariants Boolean  @default(false)
  variantLabel String?
  isActive    Boolean   @default(true)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([slug, isActive])
}

model Product {
  id                 String         @id @default(cuid())
  name               String
  slug               String         @unique
  sku                String         @unique
  hsnCode            String?
  gstRate            Decimal        @db.Decimal(5, 2) @default(18)
  shortDescription   String
  description        String
  specifications     Json
  hasVariants        Boolean        @default(false)
  price              Decimal        @db.Decimal(10, 2)
  comparePrice       Decimal?       @db.Decimal(10, 2)
  warrantyMonths     Int            @default(6)
  isFeatured         Boolean        @default(false)
  isActive           Boolean        @default(true)
  stock              Int            @default(0)
  averageRating      Float          @default(0)
  reviewCount        Int            @default(0)
  videoUrl           String?
  brandId            String
  modelId            String
  categoryId         String
  brand              Brand          @relation(fields: [brandId], references: [id])
  model              MobileModel    @relation(fields: [modelId], references: [id])
  category           Category       @relation(fields: [categoryId], references: [id])
  images             ProductImage[]
  reviews            Review[]
  inventory          Inventory?
  variants           ProductVariant[]
  orderItems         OrderItem[]
  wishlistItems      WishlistItem[]
  compatibilityModels ProductCompatibility[]
  purchaseEntries    PurchaseEntry[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@unique([brandId, modelId, categoryId, name])
  @@index([brandId, modelId, categoryId, isFeatured, isActive])
  @@index([slug, sku])
}

model ProductVariant {
  id           String   @id @default(cuid())
  productId    String
  label        String
  sku          String   @unique
  price        Decimal  @db.Decimal(10, 2)
  comparePrice Decimal? @db.Decimal(10, 2)
  stock        Int      @default(0)
  imageUrl     String?
  isDefault    Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems   OrderItem[]

  @@unique([productId, label])
  @@index([productId, isDefault, isActive])
}

model ProductCompatibility {
  id        String      @id @default(cuid())
  productId String
  modelId   String
  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  model     MobileModel @relation(fields: [modelId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([productId, modelId])
  @@index([modelId])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  alt       String?
  sortOrder Int      @default(0)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([productId, sortOrder])
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  phone         String?
  passwordHash  String
  role          UserRole       @default(CUSTOMER)
  isActive      Boolean        @default(true)
  emailVerified Boolean        @default(false)
  verifyToken   String?        @unique
  verifyTokenExpiresAt DateTime?
  resetToken    String?        @unique
  resetTokenExpiresAt DateTime?
  adminOtpCodeHash String?
  adminOtpExpiresAt DateTime?
  adminOtpChallengeToken String? @unique
  adminOtpChallengeExpiresAt DateTime?
  adminOtpLastSentAt DateTime?
  addresses     Address[]
  orders        Order[]
  reviews       Review[]
  wishlistItems WishlistItem[]
  notifications Notification[]
  supportTickets SupportTicket[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([email, role])
}

model AppSetting {
  id                 String   @id @default("default")
  siteName           String   @default("PurjiX")
  legalName          String   @default("PurjiX Mobile Spare Parts")
  supportEmail       String   @default("support@purjix.com")
  supportPhone       String   @default("+91 99999 99999")
  supportWhatsapp    String   @default("+91 99999 99999")
  supportHours       String   @default("Mon-Sat, 10 AM to 7 PM")
  addressLine1       String   @default("Repair Market, Main Unit")
  addressLine2       String   @default("Mumbai, Maharashtra")
  heroHeading        String   @default("Mobile spare parts, faster sourcing, cleaner checkout.")
  heroSubheading     String   @default("Use admin settings to keep storefront branding and support details consistent.")
  announcementText   String   @default("Free shipping above Rs. 999")
  supportBannerText  String   @default("WhatsApp support available for urgent part checks and bulk buying.")
  maintenanceMessage String   @default("We are updating the storefront and will be back shortly.")
  showDeveloperCredit Boolean @default(false)
  developerName      String   @default("")
  developerUrl       String   @default("")
  orderPrefix        String   @default("PJX")
  invoicePrefix      String   @default("INV")
  invoiceGstin       String   @default("27ABCDE1234F1Z5")
  invoiceSupportEmail String  @default("support@purjix.com")
  invoiceSupportPhone String  @default("+91 99999 99999")
  invoiceSupplyLabel String   @default("Domestic taxable supply")
  invoiceAuthorizedSignatory String @default("Authorised Signatory")
  invoiceFooterNote  String   @default("This is a computer-generated GST invoice.")
  invoiceDeclaration String   @default("We declare that this invoice shows the actual price of the goods described and that all particulars are true and correct.")
  shippingFee        Decimal  @db.Decimal(10, 2) @default(79)
  freeShippingThreshold Decimal @db.Decimal(10, 2) @default(999)
  codMaxOrderValue   Decimal  @db.Decimal(10, 2) @default(5000)
  codDisabledPincodes String  @default("")
  returnWindowDays   Int      @default(7)
  maintenanceMode    Boolean  @default(false)
  allowGuestCheckout Boolean  @default(true)
  showSupportBanner  Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model SponsorAd {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  title           String
  subtitle        String
  ctaLabel        String
  targetUrl       String
  desktopImageUrl String?
  mobileImageUrl  String?
  placement       String
  badge           String?
  priority        Int      @default(0)
  startAt         DateTime?
  endAt           DateTime?
  isActive        Boolean  @default(true)
  clickCount      Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([placement, isActive, priority])
  @@index([startAt, endAt])
}

model Address {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName    String
  line1       String
  line2       String?
  landmark    String?
  city        String
  state       String
  postalCode  String
  country     String   @default("India")
  phone       String
  gstNumber   String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, isDefault])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  productId String
  rating    Int
  title     String?
  comment   String
  status    ReviewStatus @default(PENDING)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@index([productId, status, rating])
}

model Coupon {
  id             String      @id @default(cuid())
  code           String      @unique
  description    String?
  type           CouponType
  value          Decimal     @db.Decimal(10, 2)
  minOrderValue  Decimal?    @db.Decimal(10, 2)
  maxDiscount    Decimal?    @db.Decimal(10, 2)
  usageLimit     Int?
  usedCount      Int         @default(0)
  expiresAt      DateTime?
  isActive       Boolean     @default(true)
  orders         Order[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([code, isActive, expiresAt])
}

model Order {
  id                  String         @id @default(cuid())
  orderNumber         String         @unique
  userId              String
  couponId            String?
  addressSnapshot     Json
  subtotal            Decimal        @db.Decimal(10, 2)
  discountAmount      Decimal        @db.Decimal(10, 2) @default(0)
  shippingAmount      Decimal        @db.Decimal(10, 2) @default(0)
  taxAmount           Decimal        @db.Decimal(10, 2) @default(0)
  totalAmount         Decimal        @db.Decimal(10, 2)
  notes               String?
  gstNumber           String?
  status              OrderStatus    @default(PENDING)
  paymentStatus       PaymentStatus  @default(PENDING)
  paymentRetryCount   Int            @default(0)
  paymentExpiresAt    DateTime?
  shippingCourier     String?
  shippingAwb         String?
  estimatedDeliveryAt DateTime?
  adminNotes          String?
  internalNotes       String?
  confirmedAt         DateTime?
  packedAt            DateTime?
  shippedAt           DateTime?
  deliveredAt         DateTime?
  cancelRequestedAt   DateTime?
  cancelRequestReason String?
  cancelRequestStatus RequestStatus?
  cancelDecisionAt    DateTime?
  cancelDecisionNote  String?
  cancelledAt         DateTime?
  returnRequestedAt   DateTime?
  returnRequestReason String?
  returnRequestStatus RequestStatus?
  returnDecisionAt    DateTime?
  returnDecisionNote  String?
  returnedAt          DateTime?
  refundAmount        Decimal        @db.Decimal(10, 2) @default(0)
  refundReason        String?
  refundedAt          DateTime?
  user                User           @relation(fields: [userId], references: [id])
  coupon              Coupon?        @relation(fields: [couponId], references: [id])
  items               OrderItem[]
  payment             Payment?
  invoice             Invoice?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([userId, orderNumber, status, paymentStatus])
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  productId    String
  variantId    String?
  variantLabel String?
  quantity     Int
  unitPrice    Decimal  @db.Decimal(10, 2)
  totalPrice   Decimal  @db.Decimal(10, 2)
  productName  String
  productSku   String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product  @relation(fields: [productId], references: [id])
  variant      ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([orderId, productId])
}

model Inventory {
  id              String   @id @default(cuid())
  productId       String   @unique
  stock           Int
  lowStockLimit   Int      @default(5)
  warehouseCode   String?
  lastRestockedAt DateTime?
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@index([stock, lowStockLimit])
}

model Vendor {
  id          String          @id @default(cuid())
  name        String          @unique
  contactName String?
  email       String?
  phone       String?
  gstin       String?
  address     String?
  isActive    Boolean         @default(true)
  purchases   PurchaseEntry[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([isActive, name])
}

model PurchaseEntry {
  id          String    @id @default(cuid())
  vendorId    String
  productId   String
  quantity    Int
  unitCost    Decimal   @db.Decimal(10, 2)
  totalCost   Decimal   @db.Decimal(10, 2)
  invoiceRef  String?
  notes       String?
  purchasedAt DateTime  @default(now())
  vendor      Vendor    @relation(fields: [vendorId], references: [id])
  product     Product   @relation(fields: [productId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([vendorId, purchasedAt])
  @@index([productId, purchasedAt])
}

model Payment {
  id                 String        @id @default(cuid())
  orderId            String        @unique
  provider           String        @default("RAZORPAY")
  providerOrderId    String?
  providerPaymentId  String?
  providerSignature  String?
  amount             Decimal       @db.Decimal(10, 2)
  currency           String        @default("INR")
  status             PaymentStatus @default(PENDING)
  order              Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([providerOrderId, providerPaymentId, status])
}

model Invoice {
  id            String   @id @default(cuid())
  orderId       String   @unique
  invoiceNumber String   @unique
  gstin         String?
  billingName   String
  billingEmail  String?
  billingPhone  String?
  pdfUrl        String?
  generatedAt   DateTime?
  lastDownloadedAt DateTime?
  downloadCount Int      @default(0)
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([createdAt, generatedAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  href      String?
  kind      String   @default("INFO")
  isRead    Boolean  @default(false)
  readAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}


model SupportTicket {
  id          String              @id @default(cuid())
  userId      String?
  user        User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  name        String
  email       String
  phone       String?
  subject     String
  message     String
  orderNumber String?
  kind        SupportTicketKind   @default(OTHER)
  status      SupportTicketStatus @default(NEW)
  adminNotes  String?
  resolvedAt  DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([status, createdAt])
  @@index([email, orderNumber])
}
